# Supabase Configuration
# Find these in your Supabase project dashboard under Settings → API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Vite-exposed Supabase variables (must have VITE_ prefix for client-side access)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Next.js-style aliases (alternative names that client.ts checks as fallback)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Server-side only — DO NOT expose to the client
# REQUIRED to apply database migrations (see scripts/apply-supabase-fixes.mjs)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Application URL — used for email redirect links (password reset, email verification)
# Must match the deployed URL or localhost:8080 for development
APP_URL="http://localhost:8080"
